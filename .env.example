# Copy this file to .env.local and fill in your Supabase project values.
# Find them in: Supabase Dashboard → Project Settings → API
# The anon key is meant to be public — Row Level Security protects the data.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Google OAuth client ID — powers Google Classroom roster sync (useClassroomSync)
# and Gmail send (useGmailSend), and the upcoming classroom roster import.
VITE_GOOGLE_CLIENT_ID=

# Common Curriculum planbook embed (Classroom zone → Lesson Plans). Optional.
VITE_COMMON_CURRICULUM_EMBED_URL=
